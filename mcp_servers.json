{
  "mcpServers": {
    "google_workspace": {
      "command": "npx",
      "args": ["-y", "@pegasusheavy/google-mcp"],
      "transport": "stdio",
      "autoConnect": true,
      "description": "Complete Google Workspace: Gmail, Calendar, Drive, Docs, Sheets, Slides, Meet, Chat, Forms, YouTube, Tasks, Contacts",
      "env": {
        "GOOGLE_CLIENT_ID": "",
        "GOOGLE_CLIENT_SECRET": "",
        "GOOGLE_PROJECT_ID": "",
        "GOOGLE_REFRESH_TOKEN": ""
      },
      "healthCheck": {
        "enabled": true,
        "intervalMs": 60000,
        "timeoutMs": 10000,
        "method": "ping",
        "maxFailures": 3
      },
      "reconnect": {
        "enabled": true,
        "baseDelayMs": 2000,
        "maxDelayMs": 30000,
        "maxRetries": 5
      }
    },
    "google_drive": {
      "command": "npx",
      "args": ["-y", "@pegasusheavy/google-mcp", "--services", "drive"],
      "transport": "stdio",
      "autoConnect": false,
      "description": "Google Drive file management",
      "env": {
        "GOOGLE_CLIENT_ID": "",
        "GOOGLE_CLIENT_SECRET": "",
        "GOOGLE_REFRESH_TOKEN": ""
      },
      "healthCheck": {
        "enabled": true,
        "intervalMs": 60000,
        "timeoutMs": 10000
      },
      "reconnect": {
        "enabled": true,
        "baseDelayMs": 2000,
        "maxDelayMs": 30000,
        "maxRetries": 5
      }
    },
