{
  "name": "lv-zero",
  "version": "4.0.0",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=&& .\\node_modules\\electron\\dist\\electron.exe . --no-sandbox --disable-gpu",
    "electron": "set ELECTRON_RUN_AS_NODE=&& .\\node_modules\\electron\\dist\\electron.exe . --no-sandbox --disable-gpu",
    "start:app": ".\\node_modules\\electron\\dist\\electron.exe src/main.cjs --no-sandbox --disable-gpu",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "description": "lv-zero — Open Source Node.js orchestrator powered by DeepSeek API. Agent-First, Zero Friction. Autonomous System Architect with Electron GUI.",
  "main": "src/main.cjs",
  "author": "Luis AVG",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@pegasusheavy/google-mcp": "^1.0.2",
    "@supabase/supabase-js": "^2.105.4",
    "@tavily/core": "^0.7.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "acorn": "^8.17.0",
    "acorn-loose": "^8.5.2",
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "graphify-ts": "^0.2.0",
    "ignore": "^7.0.5",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "openai": "^6.37.0",
    "pg": "^8.20.0",
    "playwright": "^1.60.0",
    "split.js": "^1.6.5",
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "vitest": "^3.1.3"
  },
  "build": {
    "appId": "com.lv-zero.app",
    "productName": "lv-zero",
    "files": [
      "src/**/*",
      "ui/**/*",
      "skills/**/*",
      "node_modules/**/*",
      "package.json",
      "LOGOLVZERO.png",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!.env"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToDir": true,
      "createDesktopShortcut": true
    }
  }
}
