# ═══════════════════════════════════════════════════════════════════════════
# lv-zero — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# lv-zero will prompt you for an API key on first run if none is set here.
# You can also leave DEEPSEEK_API_KEY empty and configure a local model below.
#

# ── Remote API (DeepSeek) ─────────────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── Local Model Fallback ──────────────────────────────────────────────────
# When DEEPSEEK_API_KEY is empty, lv-zero falls back to a local
# OpenAI-compatible server (Ollama, LM Studio, vLLM, llama.cpp, etc.).
#
# Default values (shown below) are used if not set.
LOCAL_API_URL=http://127.0.0.1:11434/v1
LOCAL_MODEL=llama3.2
# Some local servers require an API key; leave empty if not needed.
LOCAL_API_KEY=

# ── MCP Servers ───────────────────────────────────────────────────────────
# lv-zero includes 60+ preconfigured MCP servers in its registry.
# Activate the ones you need by listing their IDs here (comma-separated).
# Each server runs via `npx` on demand — no installation needed.
#
# 🗄️ Databases:        supabase, postgres, sqlite, redis, mongodb, mysql, dynamodb
# ☁️ Cloud:            cloudflare, aws, gcp, azure, docker, kubernetes, terraform, pulumi, vercel, netlify, github_actions
# 🔧 Development:      git, github, gitlab, bitbucket, jira, linear, sentry, sonarqube, playwright, puppeteer, eslint, prettier, jest, cypress
# 🤖 AI/ML:            openai, anthropic, huggingface, replicate, together, groq
# 📊 Monitoring:       grafana, datadog, newrelic, elastic
# 📝 Productivity:     slack, discord, notion, confluence, trello, asana, monday, figma, google_drive, google_calendar, gmail, outlook, teams
# 🌐 Web:              web_scraper, youtube, medium, wordpress, stripe, shopify
# 🔒 Security:         snyk, trivy, dependabot, semgrep
#
# Example: MCP_ENABLED_SERVERS=git,github,docker,postgres,slack
MCP_ENABLED_SERVERS=

# ── Web Search Providers (Phase 4 — RAG & Memory Enhancement) ────────────
# lv-zero supports multiple search providers with automatic fallback.
# Providers are tried in order of priority: Tavily > Google > Brave > SearXNG > DuckDuckGo.
#
# 🏆 Tavily (Primary — recommended)
# Get your key at: https://app.tavily.com/home
TAVILY_API_KEY=
#
# 🔍 Google Custom Search
# Requires both API key and Search Engine ID (cx).
# Get API key: https://console.cloud.google.com/apis/credentials
# Get CX:       https://programmablesearchengine.google.com/controlpanel/create
GOOGLE_API_KEY=
GOOGLE_CX=
#
# 🦁 Brave Search
# Get your key at: https://api.search.brave.com/app/dashboard
BRAVE_API_KEY=
#
# 🔎 SearXNG (Self-hosted)
# URL of your self-hosted SearXNG instance (e.g., http://192.168.1.100:4000)
# Leave empty to disable SearXNG.
SEARXNG_URL=
#
# 🦆 DuckDuckGo (Always available as final fallback)
# No configuration needed — works without API key.

# ── Image Generation (Phase 7 — Advanced Features) ───────────────────────
# lv-zero supports multiple image generation providers with automatic
# fallback. Provider auto-detection tries in order: local MCP → OpenAI → Replicate.
#
# 🤖 OpenAI DALL-E 3 (Primary cloud provider)
# Get your key at: https://platform.openai.com/api-keys
# The key can also be stored via SecretStorage (service name: "openai")
OPENAI_API_KEY=
#
# 🎨 Replicate (Stable Diffusion)
# Get your token at: https://replicate.com/account/api-tokens
# The token can also be stored via SecretStorage (service name: "replicate")
REPLICATE_API_TOKEN=
# Optional: specify a custom Replicate model (default: stability-ai/stable-diffusion-3.5-large)
# REPLICATE_MODEL=stability-ai/stable-diffusion-3.5-large
#
# 🖥️ Local (MCP Server)
# No additional configuration needed. Add an image-generation-capable MCP
# server to your MCP configuration (e.g., "stable-diffusion", "image-gen").
# The skill will auto-detect servers with "image", "stable-diffusion", or "sd" in their name.
#
# Generated images are saved to ./generated-images/ by default.
# Use the saveTo parameter to specify a custom directory.

# ── 🧠 GBrain Fusion Features (activados por defecto) ─────────────────────
# Inspirado en gbrain de Garry Tan (YC). Mejora la memoria con:
#   - Síntesis con gap analysis (gbrain_think skill)
#   - Ciclo de sueño nocturno (enriquecimiento background)
#   - Extractor de entidades automático (grafo sin LLM)
#
# Descomenta y pon false para desactivar cada feature individualmente.
# LV_GBRAIN_FEATURES=false desactiva los 3 de golpe.
LV_GBRAIN_THINK=true
LV_DREAM_CYCLE=true
LV_ENTITY_EXTRACTOR=true
# Intervalo del dream cycle en minutos (default: 5)
LV_DREAM_CYCLE_INTERVAL=5

# ── Advanced ──────────────────────────────────────────────────────────────
MAX_TOOL_ITERATIONS=50
